{
  "name": "@zuzoto/sdk",
  "version": "0.0.2",
  "description": "The official TypeScript SDK for Zuzoto - cognitive memory infrastructure for AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint src/ test/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run lint && pnpm run lint:eslint && pnpm run format:check && pnpm run test",
    "prepublishOnly": "pnpm run build",
    "prepare": "npx lefthook install",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "keywords": [
    "zuzoto",
    "ai",
    "memory",
    "llm",
    "agents",
    "rag",
    "knowledge-graph"
  ],
  "author": "Zuzoto",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zuzoto/zuzoto-typescript"
  },
  "homepage": "https://zuzoto.ai",
  "bugs": {
    "url": "https://github.com/zuzoto/zuzoto-typescript/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  }
}
